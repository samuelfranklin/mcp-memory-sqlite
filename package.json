{
  "name": "@yourorg/memory-mcp",
  "version": "0.1.0",
  "description": "MCP Memory Server - Semantic memory with SQLite + local embeddings",
  "type": "module",
  "main": "dist/server/index.js",
  "exports": {
    ".": "./dist/server/index.js"
  },
  "bin": {
    "memory-cli": "dist/bin/memory-cli.js"
  },
  "scripts": {
    "dev":           "tsx watch src/server/index.ts",
    "build":         "tsc",
    "start":         "node dist/server/index.js",
    "test":          "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch":    "vitest --watch",
    "cli":           "tsx src/bin/memory-cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers":      "^2.13.5",
    "better-sqlite3":            "^11.8.1",
    "sqlite-vec":                "0.1.7-alpha.2",
    "zod":                       "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node":           "^20.14.0",
    "@vitest/coverage-v8":   "^2.1.8",
    "tsx":                   "^4.17.0",
    "typescript":            "^5.4.5",
    "vitest":                "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "sqlite-vec", "esbuild", "sharp", "protobufjs"]
  }
}
